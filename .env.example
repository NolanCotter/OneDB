# OneDB Environment Variables

# OneDrive OAuth credentials (get from Azure App Registration or Microsoft Cloud Portal)
ONEDRIVE_CLIENT_ID=your-client-id
ONEDRIVE_CLIENT_SECRET=your-client-secret
ONEDRIVE_REDIRECT_URI=https://your-vercel-deployment.vercel.app/api/auth/callback

# Refresh token (get from OAuth callback after first authorization)
# Run the OAuth flow once, save the refresh_token, then store it here
ONEDRIVE_REFRESH_TOKEN=your-refresh-token-here

# Required: API key for authenticating requests to your OneDB instance
API_KEY=your-secure-api-key
