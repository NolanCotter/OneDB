# OneDB Environment Variables

# Option 1: Simple (token expires after ~1 hour, manual refresh needed)
ONEDRIVE_ACCESS_TOKEN=your-access-token-here

# Option 2: Auto-refresh (requires one-time OAuth setup)
ONEDRIVE_CLIENT_ID=your-client-id
ONEDRIVE_CLIENT_SECRET=your-client-secret
ONEDRIVE_REFRESH_TOKEN=your-refresh-token

# Required: API key for authenticating requests
API_KEY=your-secure-api-key
